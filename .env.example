# Sentinel Environment Configuration
# Copy this file to .env and customize for your setup
#
# IMPORTANT: Ensure .env is in .gitignore and NEVER commit the real .env file.
# Only .env.example should be committed.

# Ollama endpoint (LLM inference server)
# Default: http://localhost:11434 (standard Ollama port)
# Change to your Ollama host IP if running on a different machine
OLLAMA_URL=http://localhost:11434

# Default model name for sentinel analysis
# Set to any Ollama-compatible model name
SENTINEL_MODEL=llama3.2

# Triage model (fast, lower-cost model for initial event classification)
# Falls back to SENTINEL_MODEL if not set
# SENTINEL_TRIAGE_MODEL=llama3.2

# Deep analysis model (higher-capacity model for detailed investigation)
# Falls back to SENTINEL_MODEL if not set
# SENTINEL_DEEP_MODEL=llama3.2

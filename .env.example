# Sentinel Environment Configuration
# Copy this file to .env and customize for your setup
#
# IMPORTANT: If pushing to a public repository (e.g., GitHub),
# ensure .env is in .gitignore and NEVER commit the real .env file.
# Only .env.example should be committed.

# Ollama endpoint (LLM inference server)
# Default: http://localhost:11434 (standard Ollama port)
# Change to your Ollama host IP if running on a different machine
OLLAMA_URL=http://localhost:11434

# Default model name for sentinel analysis
# Uses hog-security-v2 by default (auto-discovered from ~/.hog/models/)
# Set to any Ollama model name to override
SENTINEL_MODEL=hog-security-v2

# Path to a specific GGUF model file (optional, overrides auto-discovery)
# HOG_MODEL_PATH=/path/to/hog-security-v2.gguf
